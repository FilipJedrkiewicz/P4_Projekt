<Window x:Class="EwidencjaPojazdow.Views.KierowcyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kierowcy / Właściciele" Height="680" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="4,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1565C0">
            <TextBlock Text="👤  Kierowcy / Właściciele" FontSize="20" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <!-- Lista -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Wyszukiwarka -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Szukaj:" VerticalAlignment="Center" Margin="0,0,6,0"
                           FontWeight="SemiBold" Foreground="#37474F"/>
                <TextBox x:Name="TxtSearch" Width="200" TextChanged="TxtSearch_TextChanged"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="DgKierowcy"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionChanged="DgKierowcy_SelectionChanged"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#EBF5FB"
                      HeadersVisibility="Column"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      BorderBrush="#B0BEC5" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PESEL" Binding="{Binding PESEL}" Width="120"/>
                    <DataGridTextColumn Header="Imię" Binding="{Binding Imie}" Width="100"/>
                    <DataGridTextColumn Header="Nazwisko" Binding="{Binding Nazwisko}" Width="120"/>
                    <DataGridTextColumn Header="Miejscowość" Binding="{Binding Miejscowosc}" Width="130"/>
                    <DataGridTextColumn Header="Data urodzenia" Binding="{Binding DataUrodzenia, StringFormat=dd.MM.yyyy}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="➕ Dodaj" Background="#2E7D32" Style="{StaticResource ActionBtn}" Click="BtnDodaj_Click"/>
                <Button Content="✏️ Edytuj" Background="#1565C0" Style="{StaticResource ActionBtn}" Click="BtnEdytuj_Click"/>
                <Button Content="🗑️ Usuń" Background="#C62828" Style="{StaticResource ActionBtn}" Click="BtnUsun_Click"/>
                <Button Content="🔄 Odśwież" Background="#546E7A" Style="{StaticResource ActionBtn}" Click="BtnOdswierz_Click"/>
            </StackPanel>
        </Grid>

        <!-- Formularz -->
        <Border Grid.Row="1" Grid.Column="1" Margin="0,10,10,10"
                Background="White" BorderBrush="#B0BEC5" BorderThickness="1">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Dane kierowcy" FontSize="14" FontWeight="Bold"
                           Foreground="#1565C0" Margin="0,0,0,12"/>

                <Label Grid.Row="1" Content="PESEL:"/>
                <TextBox Grid.Row="2" x:Name="TxtPESEL" Margin="0,0,0,8"/>

                <Label Grid.Row="3" Content="Imię:"/>
                <TextBox Grid.Row="4" x:Name="TxtImie" Margin="0,0,0,8"/>

                <Label Grid.Row="5" Content="Nazwisko:"/>
                <TextBox Grid.Row="6" x:Name="TxtNazwisko" Margin="0,0,0,8"/>

                <Label Grid.Row="7" Content="Miejscowość:"/>
                <TextBox x:Name="TxtMiejscowosc" Margin="0,4,0,8"
                         Grid.Row="8" VerticalAlignment="Top" Height="28"/>

                <StackPanel Grid.Row="9" Margin="0,4,0,0">
                    <Label Content="Data urodzenia:"/>
                    <DatePicker x:Name="DpDataUrodzenia" Margin="0,0,0,12" SelectedDateFormat="Short"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Zapisz" Background="#2E7D32" Style="{StaticResource ActionBtn}" 
                                Width="80" Click="BtnZapisz_Click"/>
                        <Button Content="Wyczyść" Background="#78909C" Style="{StaticResource ActionBtn}" 
                                Width="80" Click="BtnWyczysc_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Pasek stanu -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#1565C0">
            <TextBlock x:Name="StatusBar" Text="Gotowy" Foreground="White"
                       VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
        </Border>
    </Grid>
</Window>
