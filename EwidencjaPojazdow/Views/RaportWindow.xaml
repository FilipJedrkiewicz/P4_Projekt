<Window x:Class="EwidencjaPojazdow.Views.RaportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raport zbiorczy pojazdów" Height="560" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#37474F">
            <TextBlock Text="📊  Raport zbiorczy pojazdów — VW_ZintegrowanyRaportPojazdu" 
                       FontSize="17" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,8">
            <TextBlock Text="Szukaj:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" Foreground="#37474F"/>
            <TextBox x:Name="TxtSearch" Width="220" Padding="6,4" BorderBrush="#B0BEC5" FontSize="13" TextChanged="TxtSearch_TextChanged"/>
            <Button Content="🔄 Odśwież" Margin="12,0,0,0" Padding="12,0" Height="30"
                    Background="#546E7A" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnOdswierz_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="DgRaport" AutoGenerateColumns="True" IsReadOnly="True"
                  Margin="10,0,10,10" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#ECEFF1" HeadersVisibility="Column"
                  CanUserResizeRows="False" SelectionMode="Single"
                  BorderBrush="#B0BEC5" BorderThickness="1">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#37474F"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <Border Grid.Row="3" Background="#37474F">
            <TextBlock x:Name="StatusBar" Text="{Binding StatusBar}" Foreground="White" VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
        </Border>
    </Grid>
</Window>
