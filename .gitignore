## Ignore Visual Studio temporary files, build results, and user settings

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create to-do list files in the project directory
#MyToDos.txt

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent*

# Output directory of MSBuild publish command
AppPackages/
BundleArtifacts/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Backup & report files from converting projects
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
UpgradeLog*.xhtml

# Windows image analyses cache
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Rider
.idea/
*.sln.iml
